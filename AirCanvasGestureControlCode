// scale correction
finger.x = (int)(finger.x / SCALE);
finger.y = (int)(finger.y / SCALE);

static Point prevFinger(-1, -1);

// 🔥 smoothing (reduces shaking)
if (prevFinger.x != -1) {
    finger.x = (finger.x + prevFinger.x) / 2;
    finger.y = (finger.y + prevFinger.y) / 2;
}
prevFinger = finger;

if (finger.x >= 0 && finger.y >= 0) {

    if (fingerCount == 1) {
        // DRAW
        if (!isDrawing) {
            currentStroke.clear();
            isDrawing = true;
        }

        // 🔥 skip tiny movements (optimization + smoothness)
        if (currentStroke.empty() || norm(finger - currentStroke.back()) > 5) {
            currentStroke.push_back(finger);
        }

        circle(frame, finger, 6, Scalar(0,255,0), FILLED);
    }
    else if (fingerCount == 2) {
        // ERASE (optimized - partial erase instead of full clear)
        if (!strokes.empty()) strokes.pop_back();

        currentStroke.clear();
        isDrawing = false;

        circle(frame, finger, 6, Scalar(0,0,255), FILLED);
    }
    else {
        if (isDrawing && !currentStroke.empty()) {
            strokes.push_back(currentStroke);
            currentStroke.clear();
        }
        isDrawing = false;
    }
}
else {
    if (isDrawing && !currentStroke.empty()) {
        strokes.push_back(currentStroke);
        currentStroke.clear();
    }
    isDrawing = false;
}
